{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(docker exec *)",
      "Bash(docker logs *)",
      "Bash(docker build *)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m pytest *)",
      "Bash(alembic *)",
      "Bash(curl *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(wc *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r \".tool_input.command // empty\" 2>/dev/null); if [ -z \"$CMD\" ]; then exit 0; fi; if echo \"$CMD\" | grep -qE \"rm\\s+-rf\\s+/|git\\s+push\\s+(-f|--force)\\s+(origin\\s+)?main|DROP\\s+TABLE|shell=True\"; then echo \"BLOCKED: Gefaehrlicher Befehl erkannt\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  }
}

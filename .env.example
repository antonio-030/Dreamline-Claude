# ─── Datenbank ──────────────────────────────────────────────────────
DB_PASSWORD=dreamline_secret
DATABASE_URL=postgresql+asyncpg://dreamline:dreamline_secret@db:5432/dreamline

# ─── Sicherheit ─────────────────────────────────────────────────────
# WICHTIG: In Produktion unbedingt ändern!
DREAMLINE_SECRET_KEY=change-me-in-production

# ─── Claude-Abo Auth (macOS/Linux) ─────────────────────────────────
# Token via "claude setup-token" erzeugen (öffnet Browser, gültig ~1 Jahr)
# Oder im Dashboard unter Einstellungen → "Anmelden" eintragen
CLAUDE_CODE_OAUTH_TOKEN=

# ─── KI-Provider für das Dreaming ───────────────────────────────────
# Wähle EINEN als Standard-Provider:
# "claude-abo" = Claude Code CLI (bestehendes Abo, kein API-Key nötig)
# "codex-sub"  = Codex CLI (OpenAI Plus/Pro Abo, kein API-Key nötig)
# "ollama"     = Lokale LLMs (kostenlos, offline)
# "anthropic"  = Anthropic API (API-Key nötig)
# "openai"     = OpenAI API (API-Key nötig)
DEFAULT_AI_PROVIDER=claude-abo

# Nur nötig wenn DEFAULT_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Nur nötig wenn DEFAULT_AI_PROVIDER=openai
OPENAI_API_KEY=

# ─── Codex-Watcher ──────────────────────────────────────────────────
# Aktiviert das automatische Polling von ~/.codex/sessions/
CODEX_WATCHER_ENABLED=false
CODEX_WATCHER_INTERVAL_SECONDS=120

# ─── Ollama (lokale LLMs) ──────────────────────────────────────────
# host.docker.internal zeigt auf den Docker-Host (wo Ollama läuft)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=120.0
# Nach jedem Dream ein Custom-Modell mit Memories als System-Prompt erstellen
OLLAMA_MODELFILE_SYNC=true

# ─── autoDream (automatische Konsolidierung) ────────────────────────
AUTODREAM_ENABLED=true
AUTODREAM_MIN_HOURS=12
AUTODREAM_MIN_SESSIONS=3
AUTODREAM_SCAN_THROTTLE_MINUTES=10
DREAM_CHECK_INTERVAL_MINUTES=60

# ─── Quick-Extract ──────────────────────────────────────────────────
# Extraktion nur alle N Sessions statt nach jeder (spart API-Kosten)
EXTRACT_EVERY_N_SESSIONS=1
